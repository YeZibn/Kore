# Kore environment variables
# Copy this file to .env and fill in your values

# Workspace sandbox
KORE_WORKSPACE_ROOT=.

# LLM Provider Keys
KORE_LLM__OPENAI_API_KEY=
KORE_LLM__ANTHROPIC_API_KEY=
KORE_LLM__DEEPSEEK_API_KEY=
KORE_LLM__QWEN_API_KEY=
KORE_LLM__DEEPSEEK_THINKING_ENABLED=false

# Model settings
KORE_AGENT__CHAT_MODEL=deepseek-v4-flash
KORE_AGENT__ROUTER_MODEL=deepseek-v4-flash
KORE_AGENT__EMBEDDING_MODEL=text-embed-3-small

# Server
KORE_SERVER__HOST=127.0.0.1
KORE_SERVER__PORT=9899

# CLI preferences
KORE_CLI__TRACE_ENABLED=false
